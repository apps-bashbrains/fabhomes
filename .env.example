# Database (required for Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/fabhomes?schema=public"

# NextAuth (required for admin)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Admin seed user (only used when running db:seed). OTP login – no password.
ADMIN_SEED_PHONE="9876543210"
ADMIN_SEED_NAME="Super Admin"

# OTP: "dev" = log to console; "pinpoint" = Amazon Pinpoint SMS (set PINPOINT_* below).
OTP_PROVIDER="dev"

# Amazon Pinpoint (when OTP_PROVIDER=pinpoint)
# PINPOINT_APPLICATION_ID=""
# PINPOINT_DEFAULT_COUNTRY_CODE="91"
# PINPOINT_OTP_MESSAGE="Your verification code is {code}. Valid for 5 minutes."
# PINPOINT_ORIGINATION_NUMBER=""   # Optional: sender number if required by region

# AWS S3 (for property image uploads)
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_PROPERTY_IMAGES="fabhomes-property-images"
S3_CLOUDFRONT_URL=""

# Optional: run seed on deploy (set to true only for first deploy)
RUN_SEED_ON_DEPLOY="false"
